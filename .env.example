# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

DJANGO_SETTINGS_MODULE=config.settings.dev

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,10.10.96.138
INTERNAL_IPS=127.0.0.1

DATABASE_URL=sqlite:///db.sqlite3
# For Postgres (e.g. when using Docker):
# DATABASE_URL=postgres://postgres:postgres@db:5432/app

REDIS_URL=redis://localhost:6379/0

# Server (not required by codebase — uncomment if you use a deployment script that needs them)
# HOST=0.0.0.0
# PORT=8085

# Wagtail (optional — project includes some legacy Wagtail references)
# WAGTAIL_SITE_NAME=My Site
# WAGTAILADMIN_BASE_URL=http://localhost:8085

# Email (used in production)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# Logging
DJANGO_LOG_LEVEL=INFO

# Fiery print queue username (used when building Fiery job metadata)
FIERY_PRINT_USER=Ember

# Preflight and size tolerances (units: points for *_PT, inches where noted)
# Required bleed in points (default 9 pt = 0.125")
BLEED_PT=9.0
# Expected Canva crop-mark zone per side (pts)
CANVA_MARGIN_PT=17.0
# Tolerance around Canva detection (pts)
CANVA_WIGGLE_PT=5.0
# Rounding tolerance for exact size match (pts)
SIZE_TOLERANCE_PT=1.0
# Aspect-ratio mismatch threshold (percent)
AR_TOLERANCE_PCT=2.0
# DPI thresholds
DPI_MINIMUM=150
DPI_WARN=300
# Minimum safe zone from trim (pts)
SAFE_ZONE_PT=9.0
# Allow RGB images (True/False)
ALLOW_RGB=False
# Allow spot/Pantone colors without warning (True/False)
ALLOW_SPOT=True

# Maximum PDF upload size in bytes (default 50 MB)
MAX_PDF_UPLOAD_BYTES=52428800
